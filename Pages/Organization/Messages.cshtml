@page
@model ACC_Demo.Pages.Organization.MessagesModel
@{
    ViewData["Title"] = "Messages";
}

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card-soft p-3 sidebar-card">
            <h5 class="fw-bold">Navigation</h5>
            <div class="list-group list-group-flush mt-3">
                <a asp-page="/Organization/Dashboard"      class="list-group-item list-group-item-action">Dashboard</a>
                <a asp-page="/Organization/PostOpportunity" class="list-group-item list-group-item-action">Post Request</a>
                <a asp-page="/Organization/MyActivity"     class="list-group-item list-group-item-action">My Activity</a>
                <a asp-page="/Organization/Ledger"         class="list-group-item list-group-item-action">Time Ledger</a>
                <a asp-page="/Organization/Messages"       class="list-group-item list-group-item-action active">
                    Messages
                    @if (Model.TotalUnread > 0)
                    {
                        <span class="badge bg-danger ms-1">@Model.TotalUnread</span>
                    }
                </a>
                <a asp-page="/Organization/Profile"        class="list-group-item list-group-item-action">Profile</a>
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        <div class="card-soft p-4">
            <h4 class="acc-page-header mb-4">Messages</h4>
            @if (!Model.Conversations.Any())
            {
                <p class="text-muted">No conversations yet. Members can message you after offering help on your requests.</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (var conv in Model.Conversations)
                    {
                        <a asp-page="/Member/Chat"
                           asp-route-withUserId="@conv.OtherUserId"
                           class="list-group-item list-group-item-action @(conv.UnreadCount > 0 ? "fw-semibold" : "")">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>@conv.OtherUserName</span>
                                <small class="text-muted">@conv.LatestAt.ToLocalTime().ToString("MMM d, h:mm tt")</small>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <small class="text-muted text-truncate" style="max-width:85%">@conv.LatestMessage</small>
                                @if (conv.UnreadCount > 0)
                                {
                                    <span class="badge bg-danger ms-2">@conv.UnreadCount</span>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
