@page
@model ACC_Demo.Pages.Organization.LedgerModel
@{
    ViewData["Title"] = "Time Ledger";
}

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card-soft p-3 sidebar-card">
            <h5 class="fw-bold">Navigation</h5>
            <div class="list-group list-group-flush mt-3">
                <a asp-page="/Organization/Dashboard" class="list-group-item list-group-item-action">Dashboard</a>
                <a asp-page="/Organization/PostOpportunity" class="list-group-item list-group-item-action">Post Request</a>
                <a asp-page="/Organization/MyActivity" class="list-group-item list-group-item-action">My Activity</a>
                <a asp-page="/Organization/Ledger" class="list-group-item list-group-item-action active">Time Ledger</a>
                <a asp-page="/Organization/Messages" class="list-group-item list-group-item-action">Messages</a>
                <a asp-page="/Organization/Profile" class="list-group-item list-group-item-action">Profile</a>
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        <div style="max-width: 1000px;">

            <!-- Balance Summary -->
            <div class="row align-items-center mb-5">
                <div class="col-md-6">
                    <p class="text-uppercase text-muted small mb-1" style="letter-spacing: 0.15em;">Current Account Balance</p>
                    <div class="d-flex align-items-end gap-3">
                        <span style="font-size: 5rem; font-weight: 800; line-height: 1; color: @(Model.Balance < 0 ? "#dc3545" : "inherit");">
                            @Model.Balance.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)
                        </span>
                        <span class="text-muted fw-semibold mb-2" style="font-size: 1.4rem; letter-spacing: 0.1em;">HOURS</span>
                    </div>
                    <div class="d-flex gap-4 mt-2 text-muted small">
                        <span>↗ AVG +@Model.AvgPerWeek / WEEK</span>
                        <span>🕐 LAST UPDATE: @Model.LastUpdateLabel</span>
                    </div>
                </div>

                <div class="col-md-1 d-none d-md-flex justify-content-center">
                    <div style="width: 1px; height: 120px; background-color: #dee2e6;"></div>
                </div>

                <div class="col-md-5">
                    <div class="row g-3">
                        <div class="col-6">
                            <p class="text-uppercase text-muted small mb-0" style="letter-spacing: 0.1em;">Allocated</p>
                            <p class="fw-bold fs-4 mb-0">@Model.AllocatedHours.ToString("F1")</p>
                            <small class="text-muted fst-italic">@Model.AllocatedLabel</small>
                        </div>
                        <div class="col-6">
                            <p class="text-uppercase text-muted small mb-0" style="letter-spacing: 0.1em;">Pending</p>
                            <p class="fw-bold fs-4 mb-0">@Model.PendingHours.ToString("F1")</p>
                            <small class="text-muted fst-italic">Awaiting system verification</small>
                        </div>
                        <div class="col-6">
                            <p class="text-uppercase text-muted small mb-0" style="letter-spacing: 0.1em;">Rate</p>
                            <p class="fw-bold fs-4 mb-0">1 hour</p>
                        </div>
                        <div class="col-6">
                            <p class="text-uppercase text-muted small mb-0" style="letter-spacing: 0.1em;">Status</p>
                            <p class="fw-bold fs-4 mb-0">Active</p>
                            <small class="text-muted fst-italic">Account in good standing</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="mb-0 fw-bold">Recent Activity</h5>
                    <span class="text-muted small text-uppercase" style="letter-spacing: 0.1em;">@Model.Transactions.Count ENTRIES</span>
                </div>
                <div class="d-flex gap-2">
                    <input type="text" id="filterInput" class="form-control form-control-sm" placeholder="Filter by description..." style="width: 220px;" />
                    <button class="btn btn-sm btn-outline-secondary">⚙ FILTER</button>
                </div>
            </div>

            <hr class="mb-0" />

            <table class="table table-borderless align-middle" id="ledgerTable">
                <thead>
                    <tr class="text-uppercase text-muted small" style="letter-spacing: 0.08em; border-bottom: 1px solid #dee2e6;">
                        <th style="width: 160px;">Date</th>
                        <th>Description</th>
                        <th class="text-end" style="width: 160px;">Amount (Hrs)</th>
                        <th class="text-end" style="width: 140px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Transactions.Any())
                    {
                        @foreach (var tx in Model.Transactions)
                        {
                            <tr class="ledger-row" style="border-bottom: 1px solid #f0f0f0;">
                                <td>
                                    <div class="fw-semibold">@tx.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">TX-@tx.TransactionId</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (tx.ProviderId == Model.CurrentUserId)
                                        {
                                            <span class="d-inline-flex align-items-center justify-content-center rounded"
                                                  style="width:28px;height:28px;border:1px solid #dee2e6;">↙</span>
                                        }
                                        else
                                        {
                                            <span class="d-inline-flex align-items-center justify-content-center rounded text-white"
                                                  style="width:28px;height:28px;background:#212529;">↗</span>
                                        }
                                        <span class="ledger-desc">@(tx.Request?.Title ?? "Transaction #" + tx.TransactionId)</span>
                                    </div>
                                </td>
                                <td class="text-end fw-semibold">
                                    @(tx.ProviderId == Model.CurrentUserId ? "+" : "-")@tx.HoursTransferred.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
                                </td>
                                <td class="text-end">
                                    @if (tx.Status == "Approved")
                                    {
                                        <span class="badge border border-dark text-dark">Approved</span>
                                    }
                                    else if (tx.Status == "Confirmed")
                                    {
                                        <span class="badge border border-warning text-warning">In Review</span>
                                    }
                                    else if (tx.Status == "Disputed")
                                    {
                                        <span class="badge border border-danger text-danger">Disputed</span>
                                    }
                                    else
                                    {
                                        <span class="badge border border-secondary text-secondary">Pending</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">No transactions yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.getElementById('filterInput').addEventListener('input', function () {
        const filter = this.value.toLowerCase();
        document.querySelectorAll('.ledger-row').forEach(row => {
            const desc = row.querySelector('.ledger-desc').textContent.toLowerCase();
            row.style.display = desc.includes(filter) ? '' : 'none';
        });
    });
</script>
