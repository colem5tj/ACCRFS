@page
@model ACC_Demo.Pages.IndexModel
@{
    ViewData["Title"] = "Welcome";
}

<div class="hero-panel">
    <div class="card-soft p-5 wireframe-panel text-center">
        <h1 class="display-6 fw-bold">TimeBank Connect</h1>
        <p class="text-muted mt-3">Exchange services using time as currency. Connect members, organizations, and administrators in one structured platform.</p>
        <div class="d-grid gap-2 mt-4">
            <a asp-page="/Account/Login" class="btn btn-dark btn-lg">Sign In</a>
            <a asp-page="/Account/Register" class="btn btn-outline-dark">Create Account</a>
        </div>
    </div>
</div>
