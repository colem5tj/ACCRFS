@using Microsoft.Extensions.Localization
@using ACC_Demo
@inject IStringLocalizer<SharedResources> Localizer
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alachua Community Collective</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm mb-3">
            <div class="container">

                <!-- ACC Logo + Brand Name -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                    <img src="~/images/acc-logo.png"
                         alt="ACC Logo"
                         height="40"
                         width="40"
                         style="object-fit: contain;" />
                    <span>Alachua Community Collective</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNav"
                        aria-controls="mainNav"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-center">

                        <!-- Language Switcher -->
                        <li class="nav-item me-2">
                            <span class="navbar-text me-1" style="color: var(--acc-sage); font-size:0.85rem;">Switch Language</span>
                        </li>
                        <li class="nav-item dropdown me-3">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown">
                                🌐 @(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToUpper())
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item"
                                       href="/SetCulture?culture=en&returnUrl=@Uri.EscapeDataString(Context.Request.Path)">
                                        🇺🇸 English
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       href="/SetCulture?culture=es&returnUrl=@Uri.EscapeDataString(Context.Request.Path)">
                                        🇪🇸 Español
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Auth Links -->
                        @if (Context.Session.GetString("UserRole") != null)
                        {
                            <li class="nav-item me-2">
                                <span class="navbar-text fw-semibold" style="color: var(--acc-white);">
                                    👤 @Context.Session.GetString("UserName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Logout">@Localizer["Nav_Logout"]</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Login">@Localizer["Nav_Login"]</a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-4 py-3">
        <div class="container d-flex flex-column flex-sm-row align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <img src="~/images/acc-logo.png"
                     alt="ACC Logo"
                     height="28"
                     width="28"
                     style="object-fit: contain; opacity: 0.7;" />
                <span>&copy; @DateTime.Now.Year Alachua Community Collective</span>
            </div>
            <span style="color: var(--acc-sage); font-size: 0.82rem;">A Mutual Aid Network</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>