@page "{id:int}"
@model ACC_Demo.Pages.Member.RequestDetailsModel
@{
    ViewData["Title"] = "Request Details";
}

@if (Model.CreatorLat.HasValue)
{
    @section Styles {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    }
}

<div class="card-soft p-4 mx-auto" style="max-width: 900px;">
    <a asp-page="/Member/BrowseRequests" class="text-decoration-none">&larr; Back to Requests</a>

    <div class="d-flex justify-content-between align-items-start mt-3 mb-4">
        <div>
            <div class="text-muted small">Request #@Model.RequestItem!.RequestId</div>
            <h2 class="fw-bold">@Model.RequestItem.Title</h2>
        </div>
        <span class="status-pill status-open">@Model.RequestItem.Status</span>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <div class="border rounded-4 p-3">
                <div class="small text-uppercase text-muted mb-2">Detailed Description</div>
                <div>@Model.RequestItem.Description</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded-4 p-3">
                <div class="small text-uppercase text-muted mb-2">Hours Requested</div>
                <div class="fw-semibold">@Model.RequestItem.HoursNeeded</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded-4 p-3">
                <div class="small text-uppercase text-muted mb-2">Urgency</div>
                <div class="fw-semibold">@Model.RequestItem.UrgencyLevel</div>
            </div>
        </div>
    </div>

    @if (Model.CreatorLat.HasValue)
    {
        <div class="border rounded-4 p-3 mt-3">
            <div class="small text-uppercase text-muted mb-2">General Area</div>
            <p class="text-muted small mb-2">The shaded area shows the requester's approximate neighborhood — exact address is not shared.</p>
            <div id="requestMap" style="height: 280px; border-radius: 8px;"></div>
        </div>
    }

    <div class="d-flex justify-content-end gap-2 mt-4">
        @if (HttpContext.Session.GetInt32("UserId") != Model.RequestItem!.CreatedByUserId)
        {
            <a asp-page="/Member/Chat"
               asp-route-withUserId="@Model.RequestItem.CreatedByUserId"
               class="btn btn-outline-secondary">Message Requester</a>
        }
        <form method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="RequestItem!.RequestId" />
            <button type="submit" asp-page-handler="Decline" class="btn btn-outline-secondary">Decline Request</button>
            <button type="submit" asp-page-handler="Accept" class="btn btn-dark">Accept Request</button>
        </form>
    </div>
</div>

@if (Model.CreatorLat.HasValue)
{
    @section Scripts {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function () {
                var lat = @Model.CreatorLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var lng = @Model.CreatorLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var map = L.map('requestMap', { scrollWheelZoom: false }).setView([lat, lng], 12);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                }).addTo(map);
                L.circle([lat, lng], {
                    radius: 2000,
                    color: '#4a7c59',
                    fillColor: '#4a7c59',
                    fillOpacity: 0.25,
                    weight: 2
                }).addTo(map);
            })();
        </script>
    }
}
