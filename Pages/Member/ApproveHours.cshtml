@page
@model ACC_Demo.Pages.Member.ApproveHoursModel
@{
    ViewData["Title"] = "Approve Hours";
}

<div class="container mt-4" style="max-width: 600px;">

    <a asp-page="/Member/MyRequests" class="btn btn-secondary mb-4">← Back to My Requests</a>

    <h2 class="fw-bold mb-1">Approve Hours</h2>
    <p class="text-muted mb-4">Confirm the service was completed and rate the volunteer.</p>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (Model.Transaction == null)
    {
        <div class="alert alert-danger">Transaction not found.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <small class="text-uppercase text-muted fw-semibold d-block">Request</small>
                        <span class="fw-semibold">@Model.Transaction.Request?.Title</span>
                    </div>
                    <div class="col-6">
                        <small class="text-uppercase text-muted fw-semibold d-block">Volunteer</small>
                        <span class="fw-semibold">@Model.Transaction.Provider?.FullName</span>
                    </div>
                    <div class="col-6">
                        <small class="text-uppercase text-muted fw-semibold d-block">Estimated Hours</small>
                        <span class="fw-semibold" id="estimatedHours">@Model.Transaction.HoursTransferred hrs</span>
                    </div>
                    <div class="col-6">
                        <small class="text-uppercase text-muted fw-semibold d-block">Date</small>
                        <span class="fw-semibold">@Model.Transaction.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" name="transactionId" value="@Model.Transaction.TransactionId" />
                    <input type="hidden" name="estimatedHours" value="@Model.Transaction.HoursTransferred" />

                    <!-- Time fields -->
                    <div class="mb-4">
                        <h6 class="fw-semibold mb-3">Actual Duration</h6>
                        <div class="row g-3">
                            <div class="col-6">
                                <label for="startTime" class="form-label">Start Time</label>
                                <input type="time" id="startTime" name="startTime" class="form-control" required />
                            </div>
                            <div class="col-6">
                                <label for="endTime" class="form-label">End Time</label>
                                <input type="time" id="endTime" name="endTime" class="form-control" required />
                            </div>
                        </div>

                        <div class="mt-3 p-3 bg-light rounded" id="durationDisplay" style="display:none;">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">Calculated duration</span>
                                <span class="fw-bold" id="calculatedDuration"></span>
                            </div>
                        </div>

                        <div class="mt-2 alert alert-warning" id="overtimeWarning" style="display:none;">
                            More time will be taken from your account since the actual duration is longer than originally estimated.
                        </div>

                        <div class="mt-2 alert alert-danger" id="balanceLimitWarning" style="display:none;"></div>
                    </div>

                    <!-- Rating -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Overall, how would you rate the volunteer service performed?
                        </label>
                        <select name="rating" class="form-select" required>
                            <option value="" disabled selected>Select a rating</option>
                            <option value="1">1 — No service performed</option>
                            <option value="2">2 — Below expectations</option>
                            <option value="3">3 — Met expectations</option>
                            <option value="4">4 — Above expectations</option>
                            <option value="5">5 — Exceptional performance</option>
                        </select>
                        <small class="text-muted">This is for internal use only and will not be shown publicly.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Comments <span class="text-muted fw-normal">(optional)</span></label>
                        <textarea name="comments" class="form-control" rows="3"
                              placeholder="e.g. Volunteer was punctual and did a great job, or volunteer did not show up..."></textarea>
                        <small class="text-muted">Any notes about this experience are kept private.</small>
                    </div>

                    <div class="d-flex justify-content-end">
                        <a asp-page="/Member/MyRequests" class="btn btn-outline-secondary me-2">Cancel</a>
                        <button type="submit" class="btn btn-dark px-4">Approve & Award Hours</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const estimated = parseFloat(document.querySelector('input[name="estimatedHours"]')?.value ?? 0);
    const balance = @Model.ReceiverBalance.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const maxAllowed = +(balance + 3).toFixed(2);
    const isExempt = @(Model.IsExempt ? "true" : "false");
    const submitBtn = document.querySelector('button[type="submit"]');

    function updateDuration() {
        const start = document.getElementById('startTime').value;
        const end = document.getElementById('endTime').value;

        if (!start || !end) {
            document.getElementById('durationDisplay').style.display = 'none';
            document.getElementById('overtimeWarning').style.display = 'none';
            document.getElementById('balanceLimitWarning').style.display = 'none';
            submitBtn.disabled = false;
            return;
        }

        const [sh, sm] = start.split(':').map(Number);
        const [eh, em] = end.split(':').map(Number);

        let startMins = sh * 60 + sm;
        let endMins = eh * 60 + em;

        if (endMins <= startMins) endMins += 24 * 60;

        const totalMins = endMins - startMins;
        const hours = Math.floor(totalMins / 60);
        const mins = totalMins % 60;
        const decimal = +(totalMins / 60).toFixed(2);

        const label = mins > 0 ? `${hours}h ${mins}m (${decimal} hrs)` : `${hours}h (${decimal} hrs)`;
        document.getElementById('calculatedDuration').textContent = label;
        document.getElementById('durationDisplay').style.display = 'block';

        document.getElementById('overtimeWarning').style.display =
            decimal > estimated ? 'block' : 'none';

        const overLimit = !isExempt && decimal > maxAllowed;
        document.getElementById('balanceLimitWarning').style.display = overLimit ? 'block' : 'none';
        if (overLimit)
            document.getElementById('balanceLimitWarning').textContent =
                `This duration (${decimal} hrs) would bring your balance below -3. You can approve a maximum of ${maxAllowed} hrs.`;
        submitBtn.disabled = overLimit;
    }

    document.getElementById('startTime').addEventListener('change', updateDuration);
    document.getElementById('endTime').addEventListener('change', updateDuration);
</script>
}
