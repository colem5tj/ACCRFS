@page
@model ACC_Demo.Pages.Member.DashboardModel
@using Microsoft.Extensions.Localization
@using ACC_Demo
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = "Member Dashboard";
}
@using System.Globalization


<div class="row g-4">
    <div class="col-lg-3">
        <div class="card-soft p-3 sidebar-card">
            <h5 class="fw-bold">@Localizer["Sidebar_Navigation"] | Culture: @System.Globalization.CultureInfo.CurrentUICulture.Name</h5>            <div class="list-group list-group-flush mt-3">
                <a asp-page="/Member/Dashboard" class="list-group-item list-group-item-action active">@Localizer["Sidebar_Dashboard"]</a>
                <a asp-page="/Member/BrowseRequests" class="list-group-item list-group-item-action">@Localizer["Sidebar_BrowseRequests"]</a>
                <a asp-page="/Member/CreateRequest" class="list-group-item list-group-item-action">@Localizer["Sidebar_PostRequest"]</a>
                <a asp-page="/Member/MyRequests" class="list-group-item list-group-item-action">@Localizer["Sidebar_MyActivity"]</a>
                <a asp-page="/Member/Ledger" class="list-group-item list-group-item-action">@Localizer["Sidebar_TimeLedger"]</a>
                <a asp-page="/Member/Messages" class="list-group-item list-group-item-action">
                    Messages
                    @if (Model.UnreadDmCount > 0)
                    {
                        <span class="badge bg-danger ms-1">@Model.UnreadDmCount</span>
                    }
                </a>
                <a asp-page="/Member/Profile" class="list-group-item list-group-item-action">@Localizer["Sidebar_Profile"]</a>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card-soft p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-uppercase text-muted small">@Localizer["Dashboard_TotalTimeCredit"]</div>
                    <div class="metric-number @(Model.CurrentBalance < 0 ? "text-danger" : "")">
                        @Model.CurrentBalance.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
                    </div>
                    <div class="fw-semibold">@Localizer["Dashboard_Hours"]</div>
                </div>
                <a asp-page="/Member/Ledger" class="btn btn-outline-dark btn-sm">@Localizer["Dashboard_ViewLedger"]</a>
            </div>
        </div>
        <div class="card-soft p-4 mb-4">
            <div class="d-flex justify-content-between mb-3">
                <h5 class="fw-bold mb-0">@Localizer["Dashboard_ActiveRequests"]</h5>
                <a asp-page="/Member/MyRequests">@Localizer["Dashboard_ViewAll"]</a>
            </div>
            @foreach (var item in Model.ActiveRequests)
            {
                <div class="border rounded-4 p-3 mb-3 bg-white">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="fw-semibold">@item.Title</div>
                            <div class="text-muted small">@item.Description</div>
                        </div>
                        <span class="status-pill status-open">@item.Status</span>
                    </div>
                    <div class="small text-muted mt-2">@item.HoursNeeded hrs • @item.UrgencyLevel priority</div>
                </div>
            }
        </div>
        <div class="card-soft p-4 mb-4">
            <h5 class="fw-bold mb-3">@Localizer["Dashboard_AcceptedCommitments"]</h5>
            @foreach (var item in Model.AcceptedTransactions)
            {
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span>@item.RequestTitle</span>
                    <span class="fw-semibold">@item.Hours hrs</span>
                </div>
            }
        </div>

        <div class="card-soft p-4">
            <h5 class="fw-bold mb-2">FAQ Chatbot</h5>
            <p class="text-muted small mb-3">
                Ask a common question about hours, requests, volunteering, or your account.
            </p>

            <form method="post" asp-page-handler="Ask">
                <div class="mb-2">
                    <textarea asp-for="UserQuestion"
                              id="faqQuestion"
                              class="form-control"
                              rows="3"
                              maxlength="350"
                              placeholder="Ask a question..."></textarea>
                    <div class="d-flex justify-content-between mt-1">
                        <span asp-validation-for="UserQuestion" class="text-danger small"></span>
                        <small class="text-muted"><span id="charCount">0</span>/350</small>
                    </div>
                </div>
                <button type="submit" class="btn btn-dark">Ask</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.BotResponse))
            {
                <div class="mt-3 p-3 bg-light rounded border">
                    <strong>Answer:</strong><br />
                    @Model.BotResponse
                </div>
            }
        </div>
    </div>
    <div class="col-lg-3">
        <div class="card-soft p-3 mb-4 text-center">
            <a asp-page="/Member/BrowseRequests" class="btn btn-dark w-100 mb-2">@Localizer["Dashboard_OfferHelp"]</a>
            <a asp-page="/Member/CreateRequest" class="btn btn-outline-dark w-100">@Localizer["Dashboard_RequestAssistance"]</a>
        </div>
        <div class="card-soft p-3">
            <h6 class="fw-bold">@Localizer["Dashboard_RecentLedger"]</h6>
            @foreach (var entry in Model.RecentLedger)
            {
                <div class="d-flex justify-content-between border-bottom py-2 small">
                    <span>@entry.Description</span>
                    <span>@entry.HoursDelta</span>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const textarea = document.getElementById("faqQuestion");
            const charCount = document.getElementById("charCount");
            function updateCount() {
                if (textarea && charCount) charCount.textContent = textarea.value.length;
            }
            if (textarea) {
                textarea.addEventListener("input", updateCount);
                updateCount();
            }
        });
    </script>
}