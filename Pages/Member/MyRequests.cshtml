@page
@model ACC_Demo.Pages.Member.MyRequestsModel
@{
    ViewData["Title"] = "My Requests";
    var today = DateTime.UtcNow.Date;
}

<div class="container mt-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-page="/Member/Dashboard" class="btn btn-secondary mb-2">← Back to Dashboard</a>
            <h2>My Requests</h2>
            <p class="text-muted">Track the status of your submitted help requests</p>
        </div>
        <a href="/Member/CreateRequest" class="btn btn-primary">New Request</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (Model.Requests.Any())
    {
        @foreach (var request in Model.Requests)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h5 class="mb-1">
                                @request.Title
                                @if (request.UrgencyLevel == "High")
                                {
                                    <span class="badge bg-danger ms-2">Urgent</span>
                                }
                            </h5>
                            <small class="text-muted">Submitted @request.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        <span class="badge bg-secondary">@request.Status</span>
                    </div>

                    <p class="text-muted mb-2">@request.Description</p>

                    <div class="d-flex gap-3 mb-3">
                        <small class="text-muted"><i class="bi bi-clock"></i> @request.HoursNeeded hour(s)</small>
                        @if (request.ScheduledDate.HasValue)
                        {
                            <small class="text-muted"><i class="bi bi-calendar"></i> @request.ScheduledDate.Value.ToString("MMM dd, yyyy")</small>
                        }
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <!-- View Offers: show when request is Open or Matched -->
                        @if (request.Status == "Open" || request.Status == "Matched")
                        {
                            <a asp-page="/Member/ManageOffers"
                               asp-route-requestId="@request.RequestId"
                               class="btn btn-sm btn-outline-primary">
                                View Offers (@request.Transactions.Count)
                            </a>
                        }

                        <!-- Approve Hours: show when matched and on/after scheduled date -->
                        @if (request.Status == "Matched" &&
                                        request.AcceptedProviderId != null &&
                                        request.ScheduledDate.HasValue &&
                                        request.ScheduledDate.Value.Date <= today)
                        {
                            var confirmedTx = request.Transactions
                            .FirstOrDefault(t => t.ProviderId == request.AcceptedProviderId && t.Status == "Confirmed");
                            @if (confirmedTx != null)
                            {
                                <a asp-page="/Member/ApproveHours"
                                   asp-route-transactionId="@confirmedTx.TransactionId"
                                   class="btn btn-sm btn-success">
                                    Approve Hours
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h5 class="text-muted">No requests yet</h5>
                <p class="text-muted">Submit your first help request to get started</p>
                <a href="/Member/CreateRequest" class="btn btn-primary">Create Request</a>
            </div>
        </div>
    }
</div>