@page
@model ACC_Demo.Pages.Member.BrowseRequestsModel
@{
    ViewData["Title"] = "Browse Help Requests";
    var currentUserId = HttpContext.Session.GetInt32("UserId") ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-page="/Member/Dashboard" class="btn btn-secondary mb-2">← Back to Dashboard</a>
            <h2>Browse Help Requests</h2>
            <p class="text-muted">Find opportunities to help others in your community</p>
        </div>
        <a href="/Member/CreateRequest" class="btn btn-primary">Create New Request</a>
    </div>

    <form method="get" class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search requests..." />
                </div>
                <div class="col-md-4">
                    <select name="SkillFilter" class="form-select">
                        <option value="">All Skills</option>
                        <option value="Caregiving" selected="@(Model.SkillFilter == "Caregiving")">Caregiving</option>
                        <option value="Gardening" selected="@(Model.SkillFilter == "Gardening")">Gardening</option>
                        <option value="Shopping" selected="@(Model.SkillFilter == "Shopping")">Shopping</option>
                        <option value="Mechanical" selected="@(Model.SkillFilter == "Mechanical")">Mechanical</option>
                        <option value="Moving" selected="@(Model.SkillFilter == "Moving")">Moving</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="UrgentOnly" value="true" checked="@Model.UrgentOnly" id="urgentOnly">
                        <label class="form-check-label" for="urgentOnly">Urgent Only</label>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Apply Filters</button>
                <a href="/Member/BrowseRequests" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </form>

    <div class="mb-3">
        <p class="text-muted"><strong>@Model.Requests.Count</strong> request(s) found</p>
    </div>

    <div class="row">
        @if (Model.Requests.Any())
        {
            @foreach (var request in Model.Requests)
            {
                <div class="col-12 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h5 class="card-title mb-1">
                                        @request.Title
                                        @if (request.UrgencyLevel == "High")
                                        {
                                            <span class="badge bg-danger ms-2">Urgent</span>
                                        }
                                    </h5>
                                    <small class="text-muted">
                                        Posted @((DateTime.UtcNow - request.CreatedAt).Hours) hours ago
                                    </small>
                                </div>
                                <span class="badge bg-secondary">@request.Status</span>
                            </div>

                            <p class="card-text text-muted mb-3">@request.Description</p>

                            <div class="row g-2 mb-3">
                                <div class="col-auto">
                                    <small class="text-muted">
                                        <i class="bi bi-clock"></i> @request.HoursNeeded hour(s)
                                    </small>
                                </div>
                                @if (request.ScheduledDate.HasValue)
                                {
                                    <div class="col-auto">
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> @request.ScheduledDate.Value.ToString("MMM dd, yyyy")
                                        </small>
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <a href="/Member/RequestDetails/@request.RequestId" class="btn btn-sm btn-outline-secondary">View Details</a>
                                @if (request.CreatedByUserId == currentUserId)
                                {
                                    <button class="btn btn-sm btn-secondary" disabled>Your Request</button>
                                }
                                else
                                {
                                    <a href="/Member/OfferHelp?id=@request.RequestId" class="btn btn-sm btn-primary">Offer Help</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5">
                        <h5 class="text-muted">No requests found</h5>
                        <p class="text-muted">Try adjusting your filters or check back later</p>
                        <a href="/Member/BrowseRequests" class="btn btn-primary">Clear Filters</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-2px);
        }
</style>

