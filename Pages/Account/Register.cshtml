@page
@model ACC_Demo.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}
<div class="row justify-content-center py-4">
    <div class="col-lg-9">
        <div class="card-soft p-4 p-lg-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Profile Configuration</h2>
                    <p class="text-muted mb-0">Complete the fields below to establish your profile and availability.</p>
                </div>
            </div>

            <!-- Account type toggle -->
            <div class="mb-4 p-3 border rounded bg-light">
                <p class="fw-semibold mb-2">Are you registering as an individual or an organization?</p>
                <button type="button" class="btn btn-dark btn-sm me-2" id="btnIndividual" onclick="setAccountType('individual')">Individual</button>
                <button type="button" class="btn btn-outline-dark btn-sm" id="btnOrganization" onclick="setAccountType('organization')">Organization</button>
            </div>

            <form method="post">
                <input asp-for="Input.IsOrganization" type="hidden" id="isOrgInput" value="false" />
                <div class="row g-3">

                    <!-- Individual fields -->
                    <div class="col-md-6" id="fieldFirstName">
                        <label asp-for="Input.FirstName" class="form-label"></label>
                        <input asp-for="Input.FirstName" class="form-control" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6" id="fieldLastName">
                        <label asp-for="Input.LastName" class="form-label"></label>
                        <input asp-for="Input.LastName" class="form-control" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>

                    <!-- Organization field -->
                    <div class="col-12 d-none" id="fieldOrgName">
                        <label asp-for="Input.OrgName" class="form-label"></label>
                        <input asp-for="Input.OrgName" class="form-control" />
                        <span asp-validation-for="Input.OrgName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.PhoneNumber" class="form-label"></label>
                        <input asp-for="Input.PhoneNumber" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.Bio" class="form-label"></label>
                        <textarea asp-for="Input.Bio" class="form-control" rows="4"></textarea>
                    </div>

                    <!-- Individual-only fields -->
                    <div class="col-md-6" id="fieldSkillSummary">
                        <label asp-for="Input.SkillSummary" class="form-label"></label>
                        <input asp-for="Input.SkillSummary" class="form-control" placeholder="Tutoring, childcare, gardening" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Input.ZipCode" class="form-label"></label>
                        <input asp-for="Input.ZipCode" class="form-control" placeholder="e.g. 12345" maxlength="10" />
                        <span asp-validation-for="Input.ZipCode" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Input.SearchRadiusMiles" class="form-label"></label>
                        <input asp-for="Input.SearchRadiusMiles" class="form-control" />
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="Input.IsLocationHidden" class="form-check-input" />
                            <label asp-for="Input.IsLocationHidden" class="form-check-label"></label>
                        </div>
                        <small class="text-muted">When checked, your general neighborhood area will be visible on help requests.</small>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.PreferredContactMethod" class="form-label"></label>
                        <select asp-for="Input.PreferredContactMethod" class="form-select">
                            <option>Email</option>
                            <option>Phone</option>
                            <option>Context Messaging</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                </div>

                <!-- Age gate (individual only) -->
                <div id="ageGateWrapper">
                    <input asp-for="Input.IsMinor" type="hidden" id="isMinorInput" />
                    <input asp-for="Input.ParentEmail" type="hidden" id="parentEmailHidden" />

                    <div class="mt-4 p-3 border rounded bg-light" id="ageGateSection">
                        <p class="fw-semibold mb-2">Are you under the age of 18?</p>
                        <button type="button" class="btn btn-outline-dark btn-sm me-2" onclick="onUnder18(true)">Yes</button>
                        <button type="button" class="btn btn-outline-dark btn-sm" onclick="onUnder18(false)">No</button>
                    </div>

                    <div class="mt-3 p-3 border rounded bg-light d-none" id="under13Section">
                        <p class="fw-semibold mb-2">Are you under the age of 13?</p>
                        <button type="button" class="btn btn-outline-dark btn-sm me-2" onclick="onUnder13(true)">Yes</button>
                        <button type="button" class="btn btn-outline-dark btn-sm" onclick="onUnder13(false)">No</button>
                    </div>

                    <div class="mt-3 alert alert-danger d-none" id="under13Block">
                        No one under the age of 13 can register for an account on this website.
                    </div>

                    <div class="mt-3 alert alert-success d-none" id="adultReadyMsg">
                        You're all set — fill out the form above and submit your profile when ready.
                    </div>

                    <div class="mt-3 d-none" id="parentEmailSection">
                        <label class="form-label fw-semibold">Parent/Guardian Email</label>
                        <input type="email" id="parentEmailField" class="form-control"
                               placeholder="Enter your parent or guardian's email address" />
                        <span asp-validation-for="Input.ParentEmail" class="text-danger small"></span>
                        <small class="text-muted">Your account will be linked to your parent/guardian's existing account.</small>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end">
                    <button type="submit" class="btn btn-dark px-4" id="submitBtn">Submit Profile</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function setAccountType(type) {
            var isOrg = type === 'organization';
            document.getElementById('isOrgInput').value = isOrg ? 'true' : 'false';

            // Toggle name fields
            document.getElementById('fieldFirstName').classList.toggle('d-none', isOrg);
            document.getElementById('fieldLastName').classList.toggle('d-none', isOrg);
            document.getElementById('fieldOrgName').classList.toggle('d-none', !isOrg);

            // Toggle individual-only fields
            document.getElementById('fieldSkillSummary').classList.toggle('d-none', isOrg);
            document.getElementById('ageGateWrapper').classList.toggle('d-none', isOrg);

            // Reset minor state for orgs
            if (isOrg) {
                document.getElementById('isMinorInput').value = 'false';
                document.getElementById('submitBtn').disabled = false;
            }

            // Update button styles
            document.getElementById('btnIndividual').className = isOrg ? 'btn btn-outline-dark btn-sm me-2' : 'btn btn-dark btn-sm me-2';
            document.getElementById('btnOrganization').className = isOrg ? 'btn btn-dark btn-sm' : 'btn btn-outline-dark btn-sm';
        }

        function onUnder18(isUnder) {
            document.getElementById('under13Section').classList.toggle('d-none', !isUnder);
            document.getElementById('under13Block').classList.add('d-none');
            document.getElementById('parentEmailSection').classList.add('d-none');
            document.getElementById('adultReadyMsg').classList.toggle('d-none', isUnder);
            document.getElementById('isMinorInput').value = 'false';
            document.getElementById('parentEmailHidden').value = '';
            document.getElementById('submitBtn').disabled = false;
        }

        function onUnder13(isUnder) {
            if (isUnder) {
                document.getElementById('under13Block').classList.remove('d-none');
                document.getElementById('parentEmailSection').classList.add('d-none');
                document.getElementById('submitBtn').disabled = true;
            } else {
                document.getElementById('under13Block').classList.add('d-none');
                document.getElementById('parentEmailSection').classList.remove('d-none');
                document.getElementById('isMinorInput').value = 'true';
                document.getElementById('submitBtn').disabled = false;
            }
        }

        document.querySelector('form').addEventListener('submit', function () {
            var emailField = document.getElementById('parentEmailField');
            if (emailField && !document.getElementById('parentEmailSection').classList.contains('d-none')) {
                document.getElementById('parentEmailHidden').value = emailField.value;
            }
        });
    </script>
}
