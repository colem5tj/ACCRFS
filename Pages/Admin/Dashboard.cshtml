@page
@model ACC_Demo.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row g-4">
    <!-- Main Content -->
    <div class="col-12">

        <!-- Metric Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card-soft p-3">
                    <div class="small text-muted">Active Users</div>
                    <div class="metric-number">@Model.ActiveUsers</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card-soft p-3">
                    <div class="small text-muted">Open Requests</div>
                    <div class="metric-number">@Model.OpenRequests</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card-soft p-3">
                    <div class="small text-muted">Pending Approvals</div>
                    <div class="metric-number">@Model.PendingApprovals</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card-soft p-3">
                    <div class="small text-muted">Flagged Users</div>
                    <div class="metric-number">@Model.FlaggedUsers</div>
                </div>
            </div>
        </div>

        <!-- Tab Navigation -->
        <ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="users-tab" data-bs-toggle="tab"
                        data-bs-target="#users-panel" type="button" role="tab">
                    User Management
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="reports-tab" data-bs-toggle="tab"
                        data-bs-target="#reports-panel" type="button" role="tab">
                    Reports
                    @if (Model.AdminReports.Count > 0)
                    {
                        <span class="badge bg-danger ms-1">@Model.AdminReports.Count</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" asp-page="/Admin/ReportedChats">Reported Chats</a>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="moderation-tab" data-bs-toggle="tab"
                        data-bs-target="#moderation-panel" type="button" role="tab">
                    Moderation
                    @if (Model.FlaggedUsers > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@Model.FlaggedUsers</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="requests-tab" data-bs-toggle="tab"
                        data-bs-target="#requests-panel" type="button" role="tab">
                    All Requests
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="offers-tab" data-bs-toggle="tab"
                        data-bs-target="#offers-panel" type="button" role="tab">
                    Offer Activity
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="transactions-tab" data-bs-toggle="tab"
                        data-bs-target="#transactions-panel" type="button" role="tab">
                    Transactions
                    @if (Model.AllTransactions.Count > 0)
                    {
                        <span class="badge bg-secondary ms-1">@Model.AllTransactions.Count</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="feedback-tab" data-bs-toggle="tab"
                        data-bs-target="#feedback-panel" type="button" role="tab">
                    Feedback
                    @if (Model.LowRatingCount > 0)
                    {
                        <span class="badge bg-danger ms-1">@Model.LowRatingCount</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="archive-tab" data-bs-toggle="tab"
                        data-bs-target="#archive-panel" type="button" role="tab">
                    Archive
                    @if (Model.ArchivedUsers.Count > 0)
                    {
                        <span class="badge bg-secondary ms-1">@Model.ArchivedUsers.Count</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" href="/Admin/Profile">My Profile</a>
            </li>
        </ul>

        <div class="tab-content" id="adminTabsContent">

            <!-- ── Tab 1: User Management ───────────────────────────────── -->
            <div class="tab-pane fade show active" id="users-panel" role="tabpanel">
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">User Management</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td>@user.FullName</td>
                                        <td>
                                            <small>@user.Email</small>
                                        </td>
                                        <td>@user.RoleName</td>
                                        <td>
                                            @if (user.IsBanned)
                                            {
                                                <span class="badge bg-danger">Banned</span>
                                            }
                                            else if (user.IsFlagged)
                                            {
                                                <span class="badge bg-warning text-dark">Flagged</span>
                                            }
                                            else if (user.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                            @if (user.IsSpecialAssistance)
                                            {
                                                <span class="badge bg-info text-dark ms-1">Special Assistance</span>
                                            }
                                        </td>
                                        <td>
                                            @if (user.UserId == Model.CurrentUserId)
                                            {
                                                <span class="text-muted small">You</span>
                                            }
                                            else
                                            {
                                                <div class="d-flex gap-1 flex-wrap">
                                                    @if (user.IsBanned)
                                                    {
                                                        <form method="post" asp-page-handler="UnbanUser"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                                Unban
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="BanUser"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-warning">
                                                                Ban
                                                            </button>
                                                        </form>
                                                    }
                                                    @if (user.IsFlagged)
                                                    {
                                                        <form method="post" asp-page-handler="UnflagUser"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                                Unflag
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="FlagUser"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                                                Flag
                                                            </button>
                                                        </form>
                                                    }
                                                    <form method="post" asp-page-handler="ArchiveUser"
                                                          asp-route-userId="@user.UserId" class="d-inline"
                                                          onsubmit="return confirm('Archive @user.FullName? Their profile will be moved to the Archive tab where it can be permanently deleted.');">
                                                        <button type="submit" class="btn btn-sm btn-secondary">
                                                            Archive
                                                        </button>
                                                    </form>
                                                    @if (user.IsSpecialAssistance)
                                                    {
                                                        <form method="post" asp-page-handler="RevokeSpecialAssistance"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-info">
                                                                Revoke Assistance
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="GrantSpecialAssistance"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-info">
                                                                Special Assistance
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ── Tab 2: Reports ───────────────────────────────────────── -->
            <div class="tab-pane fade" id="reports-panel" role="tabpanel">
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">Admin Reports</h5>
                    @if (Model.AdminReports.Count == 0)
                    {
                        <p class="text-muted">No reports have been submitted.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Reported By</th>
                                        <th>Reported User</th>
                                        <th>Reason</th>
                                        <th>Date</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var report in Model.AdminReports)
                                    {
                                        <tr>
                                            <td class="text-muted small">@report.AdminReportId</td>
                                            <td>
                                                @report.ReporterName<br />
                                                <small class="text-muted">@report.ReporterEmail</small>
                                            </td>
                                            <td>
                                                @report.ReportedUserName
                                                @if (report.IsReportedUserFlagged)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1">Flagged</span>
                                                }
                                                <br />
                                                <small class="text-muted">@report.ReportedUserEmail</small>
                                            </td>
                                            <td style="max-width:260px;">
                                                <span class="text-truncate d-inline-block" style="max-width:240px;"
                                                      title="@report.Reason">@report.Reason</span>
                                            </td>
                                            <td class="small text-nowrap">
                                                @report.CreatedAt.ToString("MM/dd/yyyy")
                                            </td>
                                            <td>
                                                @if (!report.IsReportedUserFlagged)
                                                {
                                                    <form method="post" asp-page-handler="FlagUser"
                                                          asp-route-userId="@report.ReportedUserId" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-warning">
                                                            Flag User
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Already flagged</span>
                                                }
                                                <form method="post" asp-page-handler="DismissReport"
                                                      asp-route-reportId="@report.AdminReportId" class="d-inline ms-1">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                            onclick="return confirm('Remove this report?')">
                                                        Dismiss
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- ── Tab 3: Moderation ────────────────────────────────────── -->
            <div class="tab-pane fade" id="moderation-panel" role="tabpanel">

                <!-- Flagged Users section -->
                <div class="card-soft p-4 mb-4">
                    <h5 class="fw-bold mb-3">
                        Flagged Users
                        @if (Model.FlaggedUsersList.Count > 0)
                        {
                            <span class="badge bg-warning text-dark ms-2">@Model.FlaggedUsersList.Count</span>
                        }
                    </h5>
                    @if (Model.FlaggedUsersList.Count == 0)
                    {
                        <p class="text-muted">No users are currently flagged.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Banned?</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.FlaggedUsersList)
                                    {
                                        <tr>
                                            <td>@user.FullName</td>
                                            <td><small>@user.Email</small></td>
                                            <td>@user.RoleName</td>
                                            <td>
                                                @if (user.IsBanned)
                                                {
                                                    <span class="badge bg-danger">Yes</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">No</span>
                                                }
                                            </td>
                                            <td>
                                                @if (user.UserId == Model.CurrentUserId)
                                                {
                                                    <span class="text-muted small">You</span>
                                                }
                                                else
                                                {
                                                    <div class="d-flex gap-1 flex-wrap">
                                                        <form method="post" asp-page-handler="UnflagUser"
                                                              asp-route-userId="@user.UserId" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                                Unflag
                                                            </button>
                                                        </form>
                                                        @if (!user.IsBanned)
                                                        {
                                                            <form method="post" asp-page-handler="BanUser"
                                                                  asp-route-userId="@user.UserId" class="d-inline">
                                                                <button type="submit" class="btn btn-sm btn-warning">
                                                                    Ban
                                                                </button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <form method="post" asp-page-handler="UnbanUser"
                                                                  asp-route-userId="@user.UserId" class="d-inline">
                                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                                    Unban
                                                                </button>
                                                            </form>
                                                        }
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <!-- Flag any user section -->
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">Unflagged Users</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td>@user.FullName</td>
                                        <td><small>@user.Email</small></td>
                                        <td>@user.RoleName</td>
                                        <td>
                                            @if (user.IsFlagged)
                                            {
                                                <span class="badge bg-warning text-dark">Flagged</span>
                                            }
                                            else if (user.IsBanned)
                                            {
                                                <span class="badge bg-danger">Banned</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                        </td>
                                        <td>
                                            @if (user.IsFlagged)
                                            {
                                                <form method="post" asp-page-handler="UnflagUser"
                                                      asp-route-userId="@user.UserId" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                        Unflag
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="FlagUser"
                                                      asp-route-userId="@user.UserId" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                                        Flag
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ── Tab 4: All Requests ──────────────────────────────────── -->
            <div class="tab-pane fade" id="requests-panel" role="tabpanel">
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">All Submitted Requests</h5>
                    @if (Model.AllRequests.Count == 0)
                    {
                        <p class="text-muted">No requests have been submitted yet.</p>
                    }
                    else
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Title</th>
                                    <th>Requested By</th>
                                    <th>Hours</th>
                                    <th>Status</th>
                                    <th>Accepted By</th>
                                    <th>Submitted</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in Model.AllRequests)
                                {
                                    <tr>
                                        <td>@req.RequestId</td>
                                        <td>@req.Title</td>
                                        <td>
                                            @req.RequesterName<br />
                                            <small class="text-muted">@req.RequesterEmail</small>
                                        </td>
                                        <td>@req.HoursNeeded</td>
                                        <td>
                                            <span class="badge @(req.Status == "Open" ? "bg-primary" : req.Status == "Completed" ? "bg-success" : "bg-secondary")">
                                                @req.Status
                                            </span>
                                        </td>
                                        <td>@req.AcceptedByName</td>
                                        <td>@req.CreatedAt.ToString("MM/dd/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <!-- ── Tab 5: Offer Activity ────────────────────────────────── -->
            <div class="tab-pane fade" id="offers-panel" role="tabpanel">
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">Offer Activity</h5>
                    @if (Model.OfferActivity.Count == 0)
                    {
                        <p class="text-muted">No offers have been made yet.</p>
                    }
                    else
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Request</th>
                                    <th>Requested By</th>
                                    <th>Help Offered By</th>
                                    <th>Hours</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var offer in Model.OfferActivity)
                                {
                                    <tr>
                                        <td>@offer.RequestTitle</td>
                                        <td>@offer.RequesterName</td>
                                        <td>
                                            @offer.ProviderName<br />
                                            <small class="text-muted">@offer.ProviderEmail</small>
                                        </td>
                                        <td>@offer.HoursNeeded</td>
                                        <td>
                                            <span class="badge @(offer.Status == "Open" ? "bg-primary" : offer.Status == "Completed" ? "bg-success" : "bg-secondary")">
                                                @offer.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <!-- ── Tab 6: Transactions ─────────────────────────────────────── -->
            <div class="tab-pane fade" id="transactions-panel" role="tabpanel">
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">Transaction History</h5>
                    @if (Model.AllTransactions.Count == 0)
                    {
                        <p class="text-muted">No transactions have been recorded yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Request</th>
                                        <th>Provider (gave hours)</th>
                                        <th>Receiver (got hours)</th>
                                        <th>Hours</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Confirmed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.AllTransactions)
                                    {
                                        <tr>
                                            <td class="text-muted small">@t.TransactionId</td>
                                            <td>@t.RequestTitle</td>
                                            <td>
                                                @t.ProviderName<br />
                                                <small class="text-muted">@t.ProviderEmail</small>
                                            </td>
                                            <td>
                                                @t.ReceiverName<br />
                                                <small class="text-muted">@t.ReceiverEmail</small>
                                            </td>
                                            <td>@t.HoursTransferred</td>
                                            <td>
                                                @{
                                                    var badgeClass = t.Status switch
                                                    {
                                                        "Approved"      => "bg-success",
                                                        "Completed"     => "bg-success",
                                                        "PendingReview" => "bg-warning text-dark",
                                                        "Pending"       => "bg-warning text-dark",
                                                        "Rejected"      => "bg-danger",
                                                        _               => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@t.Status</span>
                                            </td>
                                            <td class="small text-nowrap">@t.CreatedAt.ToLocalTime().ToString("MM/dd/yyyy h:mm tt")</td>
                                            <td class="small text-nowrap">
                                                @(t.ConfirmedAt.HasValue ? t.ConfirmedAt.Value.ToLocalTime().ToString("MM/dd/yyyy h:mm tt") : "—")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- ── Tab 7: Feedback ──────────────────────────────────────── -->
            <div class="tab-pane fade" id="feedback-panel" role="tabpanel">

                @if (Model.LowRatingCount > 0)
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2 mb-3">
                        <span style="font-size:1.2rem;">&#9888;</span>
                        <div>
                            <strong>@Model.LowRatingCount hour@(Model.LowRatingCount > 1 ? "s" : "") on hold — pending your review</strong>
                            <ul class="mb-0 mt-1">
                                @foreach (var fb in Model.AllFeedback.Where(f => f.Rating == 1 && f.TransactionStatus == "PendingReview"))
                                {
                                    <li>
                                        <strong>@fb.VolunteerName</strong> &mdash; rated 1/5 by @fb.GivenByName
                                        @if (!string.IsNullOrWhiteSpace(fb.Comments))
                                        {
                                            <span class="text-muted fst-italic">&ldquo;@fb.Comments&rdquo;</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">Submitted Feedback</h5>
                    @if (Model.AllFeedback.Count == 0)
                    {
                        <p class="text-muted">No feedback has been submitted yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Volunteer</th>
                                        <th>Reviewed By</th>
                                        <th>Rating</th>
                                        <th>Tags</th>
                                        <th>Comments</th>
                                        <th>Hours</th>
                                        <th>Hours Decision</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fb in Model.AllFeedback)
                                    {
                                        <tr class="@(fb.Rating == 1 && fb.TransactionStatus == "PendingReview" ? "table-danger" : "")">
                                            <td>
                                                <strong>@fb.VolunteerName</strong><br />
                                                <small class="text-muted">@fb.VolunteerEmail</small>
                                            </td>
                                            <td>
                                                @fb.GivenByName<br />
                                                <small class="text-muted">@fb.GivenByEmail</small>
                                            </td>
                                            <td>
                                                @if (fb.Rating == 1)
                                                {
                                                    <span class="badge bg-danger me-1">&#9888; Low</span>
                                                }
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <span style="color: @(i <= fb.Rating ? "#f5a623" : "#ccc")">&#9733;</span>
                                                }
                                            </td>
                                            <td>
                                                @if (fb.IsCheerful)
                                                {
                                                    <span class="badge bg-info me-1">Cheerful</span>
                                                }
                                                @if (fb.IsEfficient)
                                                {
                                                    <span class="badge bg-info me-1">Efficient</span>
                                                }
                                                @if (fb.IsOnTime)
                                                {
                                                    <span class="badge bg-info me-1">On Time</span>
                                                }
                                                @if (fb.IsHighlySkilled)
                                                {
                                                    <span class="badge bg-info me-1">Highly Skilled</span>
                                                }
                                            </td>
                                            <td>@(string.IsNullOrWhiteSpace(fb.Comments) ? "—" : fb.Comments)</td>
                                            <td>@fb.HoursTransferred</td>
                                            <td>
                                                @if (fb.Rating == 1 && fb.TransactionStatus == "PendingReview")
                                                {
                                                    <div class="d-flex gap-1">
                                                        <form method="post" asp-page-handler="ApproveTransaction"
                                                              asp-route-transactionId="@fb.TransactionId">
                                                            <button type="submit" class="btn btn-sm btn-success"
                                                                    title="Award hours to volunteer">
                                                                Award
                                                            </button>
                                                        </form>
                                                        <form method="post" asp-page-handler="RejectTransaction"
                                                              asp-route-transactionId="@fb.TransactionId">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                                    title="Withhold hours from volunteer">
                                                                Withhold
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                                else if (fb.Rating == 1 && fb.TransactionStatus == "Approved")
                                                {
                                                    <span class="badge bg-success">Awarded</span>
                                                }
                                                else if (fb.Rating == 1 && fb.TransactionStatus == "Rejected")
                                                {
                                                    <span class="badge bg-secondary">Withheld</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- ── Tab 7: Archive ───────────────────────────────────────── -->
            <div class="tab-pane fade" id="archive-panel" role="tabpanel">
                <div class="card-soft p-4">
                    <h5 class="fw-bold mb-3">Archived Accounts</h5>
                    <p class="text-muted small mb-3">
                        Archived accounts are deactivated and hidden from all other views.
                        Permanent deletion can only be done from here.
                    </p>
                    @if (Model.ArchivedUsers.Count == 0)
                    {
                        <p class="text-muted">No archived accounts.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Flags</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.ArchivedUsers)
                                    {
                                        <tr>
                                            <td>@user.FullName</td>
                                            <td><small>@user.Email</small></td>
                                            <td>@user.RoleName</td>
                                            <td>
                                                @if (user.IsBanned)
                                                {
                                                    <span class="badge bg-danger me-1">Banned</span>
                                                }
                                                @if (user.IsFlagged)
                                                {
                                                    <span class="badge bg-warning text-dark me-1">Flagged</span>
                                                }
                                                @if (user.IsSpecialAssistance)
                                                {
                                                    <span class="badge bg-info text-dark me-1">Special Assistance</span>
                                                }
                                                @if (!user.IsBanned && !user.IsFlagged && !user.IsSpecialAssistance)
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex gap-1 flex-wrap">
                                                    <form method="post" asp-page-handler="UnarchiveUser"
                                                          asp-route-userId="@user.UserId" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                                            Unarchive
                                                        </button>
                                                    </form>
                                                    <form method="post" asp-page-handler="DeleteUser"
                                                          asp-route-userId="@user.UserId" class="d-inline"
                                                          onsubmit="return confirm('Permanently delete @user.FullName and ALL their data? This cannot be undone.');">
                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                            Delete Permanently
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div><!-- end tab-content -->
    </div><!-- end col-lg-9 -->
</div><!-- end row -->

